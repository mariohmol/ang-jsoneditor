{
  "name": "ang-jsoneditor",
  "version": "5.0.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mariohmol/ang-jsoneditor"
  },
  "license": "MIT",
  "packageManager": "pnpm@9",
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "immutable": ">=5.1.5"
    }
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:app": "npm run build:lib && ng build",
    "build:lib": "ng build --project ang-jsoneditor",
    "watch": "npm run build:lib -- --watch",
    "build:full": "npm run build:lib && npm run build:app",
    "build:pages": "npm run build:lib && ng build --base-href /ang-jsoneditor/ --output-path dist/pages && cp -r dist/pages/browser/. docs/ && rm -rf dist/pages",
    "publishnpm": "cp README.md projects/ang-jsoneditor/README.md && npm run build:lib && cd dist/ang-jsoneditor && npm publish",
    "unpublish": "npm deprecate -f 'ang-jsoneditor@1.9.3' 'this package has been deprecated'",
    "test": "npm run test:dev && npm run e2e",
    "test:dev": "ng test --project ang-jsoneditor-demo",
    "test:unit": "ng test",
    "test:ci": "ng test --project ang-jsoneditor --watch=false --browsers=ChromeHeadless",
    "deploy:demo": "npm run build:lib && ng build --base-href /ang-jsoneditor/ && cp -r dist/ang-jsoneditor-demo/browser/. /var/www/test/ang-jsoneditor/",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "ports": "lsof -i tcp:4201",
    "reinstall": "rm package-lock.json && rm -rf node_modules && npm i",
    "rebuildsass": "npm rebuild node-sass"
  },
  "dependencies": {
    "@angular/common": "^20.1.3",
    "@angular/compiler": "^20.1.3",
    "@angular/core": "^20.1.3",
    "@angular/forms": "^20.1.3",
    "@angular/platform-browser": "^20.1.3",
    "@angular/platform-browser-dynamic": "^20.1.3",
    "@angular/router": "^20.1.3",
    "jsoneditor": "*",
    "ng-packagr": "^20.1.0",
    "rxjs": "*",
    "tslib": "^2.3.0",
    "webpack": "^5.104.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^20.1.3",
    "@angular-eslint/builder": "^18.0.0",
    "@angular-eslint/eslint-plugin": "^18.0.0",
    "@angular-eslint/eslint-plugin-template": "^18.0.0",
    "@angular-eslint/schematics": "^18.0.0",
    "@angular-eslint/template-parser": "^18.0.0",
    "@angular/build": "^20.1.3",
    "@angular/cli": "^20.1.3",
    "@angular/compiler-cli": "^20.1.3",
    "@angular/language-service": "^20.1.3",
    "@types/jasmine": "~5.1.2",
    "@types/jsoneditor": "^9.9.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cpr": "^3.0.1",
    "eslint": "^8.53.0",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-prefer-arrow": "latest",
    "jasmine-core": "~5.1.0",
    "karma": "6.4.2",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "5.8.3"
  }
}